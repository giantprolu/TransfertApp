generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String?  @unique
  name      String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  spotifyToken    SpotifyToken?
  appleMusicToken AppleMusicToken?
  imports         Import[]

  @@map("users")
}

model SpotifyToken {
  id           String   @id @default(uuid())
  userId       String   @unique @map("user_id")
  accessToken  String   @map("access_token")
  refreshToken String   @map("refresh_token")
  expiresAt    DateTime @map("expires_at")
  scope        String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("spotify_tokens")
}

model AppleMusicToken {
  id        String   @id @default(uuid())
  userId    String   @unique @map("user_id")
  userToken String   @map("user_token")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("apple_music_tokens")
}

model Import {
  id              String       @id @default(uuid())
  userId          String       @map("user_id")
  source          String       @default("spotify")
  sourcePlaylist  String?      @map("source_playlist")
  targetPlaylist  String?      @map("target_playlist")
  status          ImportStatus @default(PENDING)
  totalTracks     Int          @default(0) @map("total_tracks")
  matchedTracks   Int          @default(0) @map("matched_tracks")
  failedTracks    Int          @default(0) @map("failed_tracks")
  errorMessage    String?      @map("error_message")
  startedAt       DateTime?    @map("started_at")
  completedAt     DateTime?    @map("completed_at")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  tracks Track[]

  @@map("imports")
}

model Track {
  id               String      @id @default(uuid())
  importId         String      @map("import_id")
  spotifyTrackId   String?     @map("spotify_track_id")
  spotifyTitle     String      @map("spotify_title")
  spotifyArtist    String      @map("spotify_artist")
  spotifyAlbum     String?     @map("spotify_album")
  appleMusicId     String?     @map("apple_music_id")
  appleMusicTitle  String?     @map("apple_music_title")
  appleMusicArtist String?     @map("apple_music_artist")
  matchScore       Float?      @map("match_score")
  status           TrackStatus @default(PENDING)
  errorMessage     String?     @map("error_message")
  createdAt        DateTime    @default(now()) @map("created_at")

  import Import @relation(fields: [importId], references: [id], onDelete: Cascade)

  @@map("tracks")
}

enum ImportStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
}

enum TrackStatus {
  PENDING
  MATCHED
  NOT_FOUND
  FAILED
}
